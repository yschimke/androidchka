# Per-clone overlay configuration. Copy this file to `local.properties` and edit to taste.
# `local.properties` is git-ignored; `local.properties.example` is committed and provides the
# defaults used when no `local.properties` exists.
#
# androidx.sources: comma-separated Gradle project paths to build from the upstream androidx
# checkout. The relative directory under `androidx/` is derived by replacing `:` with `/`,
# unless an entry uses the `:path = relative/dir` form to override.
#
# Stubs for every other project referenced by these are auto-populated.

androidx.sources=:wear:compose:remote:remote-material3,:compose:remote:remote-creation-compose

# Extra Gradle config (additional plugins, dependencies, task tweaks) is applied via the
# convention plugin at build-logic/src/main/kotlin/androidchka.extras.gradle.kts. Edit that
# file directly — it's a normal Kotlin DSL build script.
